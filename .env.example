# Anthropic (Claude models for analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter (alternative to Anthropic — set one or the other)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (text-embedding-3-large for embeddings — required)
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant vector DB (preferred — auto-detected)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=samsung_voc_reviews

# Pinecone (fallback vector DB)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=voc-samsung-tv
PINECONE_ENVIRONMENT=us-east-1

# Samsung Product Config
SAMSUNG_PRODUCT_URL=https://www.samsung.com/us/tvs/uhd-4k-tv/50-inch-class-crystal-uhd-u7900f-4k-smart-tv-sku-un50u7900ffxza/
SAMSUNG_MODEL_CODE=UN50U7900FFXZA
SAMSUNG_PRODUCT_ID=UN50U7900FFXZA

# BazaarVoice API (Samsung review API)
BV_PASSKEY=
BV_API_URL=https://api.bazaarvoice.com/data/reviews.json

# Model configuration
MODEL_HAIKU=claude-haiku-4-5-20251001
MODEL_SONNET=claude-sonnet-4-6
MODEL_OPUS=claude-opus-4-8
EMBEDDING_MODEL=text-embedding-3-large

# Pipeline config
MAX_REVIEWS=500
BATCH_SIZE=20
ENABLE_RAG=true
OUTPUT_DIR=data/reports
